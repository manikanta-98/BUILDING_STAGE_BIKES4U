PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/ak-bikes
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
ADMIN_KEY=change-this-admin-secret
JWT_SECRET=change-this-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
# Comma-separated emails that get admin role on signup
ADMIN_EMAILS=admin@akbikes.com
# When MongoDB is down, serve bikes from ../bikes (1).json (dev only)
ALLOW_JSON_FALLBACK=true
